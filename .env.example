# Скопируй в .env и заполни значения:
#   cp .env.example .env

# Telegram Bot Token от @BotFather
BOT_TOKEN=

# API-ключ с https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Лиги для загрузки (коды football-data.org), через запятую
FOOTBALL_DATA_COMPETITIONS=CL,WC

# На сколько дней вперёд подгружать матчи
FOOTBALL_DATA_DAYS_AHEAD=7

PORT=8080
DB_PATH=/data/football.db
SCHEMA_PATH=internal/repository/schema.sql
STATIC_DIR=static
ENABLE_WORKER=true

# Для одного сервера можно оставить пустым
CORS_ORIGIN=
