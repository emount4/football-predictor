# Бэкенд: .env в корне репозитория (для docker compose)
#   cp .env.example .env
#
# Или backend/.env при запуске: cd backend && go run ./cmd/server

BOT_TOKEN=
FOOTBALL_DATA_TOKEN=

FOOTBALL_DATA_COMPETITIONS=CL,WC
FOOTBALL_DATA_DAYS_AHEAD=7

PORT=8080

# Локально без Docker:
# DB_PATH=data/football.db
# SCHEMA_PATH=internal/repository/schema.sql

# Docker (docker compose):
DB_PATH=/data/football.db
SCHEMA_PATH=internal/repository/schema.sql

# API-only (фронт на Vercel) — статику Go не отдаём:
STATIC_DIR=

ENABLE_WORKER=true

# URL фронта на Vercel — обязательно для CORS (с https://, без слэша в конце)
# CORS_ORIGIN=https://football-predictor-xxx.vercel.app
CORS_ORIGIN=
