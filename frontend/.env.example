# === Локальная разработка (npm run dev) ===
# Vite проксирует /api на localhost:8080 — можно оставить так:
VITE_API_BASE_URL=http://localhost:8080

# Для теста в обычном браузере (не Telegram) — вставь initData из Mini App.
# В Telegram не нужен, оставь пустым.
VITE_DEV_INIT_DATA=

# === Прод: Vercel + бэкенд через Cloudflare Tunnel ===
# На Vercel эти переменные задаются в Dashboard → Settings → Environment Variables
# (не коммить .env с реальными URL в git)
#
# VITE_API_BASE_URL=https://xxxx.trycloudflare.com
# VITE_DEV_INIT_DATA=
#
# URL туннеля — без слэша в конце.
# После каждого перезапуска quick tunnel URL меняется → обнови в Vercel и Redeploy.
